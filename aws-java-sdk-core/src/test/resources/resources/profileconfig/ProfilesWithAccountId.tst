[default]
aws_access_key_id = defaultAccessKey
aws_secret_access_key = defaultSecretAccessKey
aws_account_id = defaultAccountId

[a]
aws_access_key_id=a
aws_secret_access_key=a
aws_account_id=a

[b]
aws_access_key_id=b
aws_secret_access_key=b
aws_account_id=b

[c]
aws_access_key_id=c
aws_secret_access_key=c
aws_session_token=c
aws_account_id=c

[d]
aws_access_key_id=d
aws_secret_access_key=d
aws_session_token=d
aws_account_id=d
